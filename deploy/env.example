# RaidPlans API environment.
# Copy to /etc/raidplans/env on the server, then `chmod 600`. Never commit real
# secrets — this file only documents the keys.
#
# For where the Discord values come from, see deploy/discord-oauth.md.

PORT=4000
NODE_ENV=production

# Public origin of the API. Must be https in production, or the session cookie
# (Secure) is rejected and login silently loops.
BASE_URL=https://raidplans.mamzer.dev

# Where the SPA is served from — users land here after signing in.
# In production Caddy serves the app and the API from one origin, so this
# defaults to BASE_URL and can be left unset. In development it defaults to
# Vite's http://localhost:5173 (the API serves no `/` to land on).
# WEB_ORIGIN=

# SQLite file (plan §14). The directory must be writable by the service user;
# the systemd unit's StateDirectory creates /var/lib/raidplans.
DATABASE_PATH=/var/lib/raidplans/app.db

# --- Auth (plan §10) ---
# The API refuses to boot in production unless all three are set.

# Signs session cookies. Minimum 32 chars (the API won't boot below that).
# Generate with: openssl rand -base64 32  → 44 chars.
# Rotating it logs everyone out.
SESSION_SECRET=

# Discord Developer Portal → your application → OAuth2.
# The client secret is shown only once; reset it there if lost.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Your Discord server's id ("guild" is just the API's name for a server):
# Discord → Settings → Advanced → Developer Mode, then right-click the server
# → Copy Server ID. Only members of THIS server may sign in — checked with the
# `guilds.members.read` scope, which asks Discord about this one server rather
# than listing every server the user is in.
DISCORD_GUILD_ID=

# Optional: map Discord roles onto RaidPlans roles (right-click a role →
# Copy Role ID). Without these, every server member gets DISCORD_DEFAULT_ROLE.
# DISCORD_OWNER_ROLE_IDS=
# DISCORD_EDITOR_ROLE_IDS=
# DISCORD_DEFAULT_ROLE=viewer

# --- Uploads (plan §4.8) ---
# Where custom backgrounds are written. Must be writable by the service user
# and included in your backups (the DB alone won't restore them).
# Only PNG/JPEG/WebP/GIF are accepted, and the file's *bytes* decide its type —
# SVG is rejected outright (it can carry scripts).
UPLOAD_DIR=/var/lib/raidplans/uploads
