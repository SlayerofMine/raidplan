# RaidPlans — Caddy reverse proxy + automatic TLS (plan §14).
# Requires TCP 80/443 open in BOTH the OCI VCN security list AND firewalld,
# or ACME/Let's Encrypt cannot complete.

raidplans.mamzer.dev {
	encode gzip

	# App API, tRPC, and public share/OG routes are served by the Node service.
	# /p/* is the *share link*: the API renders it with Open Graph meta so
	# Discord unfurls a preview (it doesn't run JS, so the SPA shell would show
	# it nothing). That page then hands people to the SPA's own viewer at
	# /view/:slug, which is served as a static route below.
	reverse_proxy /api/* localhost:4000
	reverse_proxy /trpc/* localhost:4000
	reverse_proxy /p/* localhost:4000

	# Uploaded maps (plan §4.8). The API serves these from UPLOAD_DIR, checking
	# the asset exists and setting nosniff. Without this route `try_files` below
	# would answer with index.html and every custom map would silently fail to
	# decode.
	reverse_proxy /uploads/* localhost:4000

	# Everything else is the built SPA. `try_files` gives client-side routing
	# (deep links like /plan/:id/edit) a working refresh.
	root * /srv/web
	try_files {path} /index.html
	file_server
}
