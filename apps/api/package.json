{
  "name": "@raidplan/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "RaidPlans backend \u2014 Hono server, tRPC router, SQLite persistence, Discord auth.",
  "exports": {
    "./trpc": "./src/trpc/appRouter.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "icons:sync": "tsx --env-file-if-exists=.env src/jobs/syncIconsCli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.3.4",
    "@raidplan/shared": "workspace:*",
    "@trpc/server": "^11.0.0-rc.660",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "pino": "^9.5.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3",
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
