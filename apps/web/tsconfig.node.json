{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // DOM is here for the E2E specs: `addInitScript`/`evaluate` callbacks are
    // serialized and run inside the browser, so they legitimately touch
    // `window`/`localStorage` even though the runner itself is Node.
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "playwright.auth.config.ts",
    "e2e"
  ]
}
